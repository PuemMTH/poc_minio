# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=poc_minio

# === Backend ===
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/poc_minio
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/poc_minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=uploads
UPLOAD_MAX_SIZE_MB=100
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# === Frontend (build-time) ===
VITE_API_BASE_URL=/api
